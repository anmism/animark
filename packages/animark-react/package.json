{
  "name": "animark-react",
  "version": "2.0.0",
  "description": "Animated inline Markdown for React — per-scope isolated animation state",
  "author": "anmism",
  "license": "MIT",
  "homepage": "https://github.com/anmism/animark#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/anmism/animark.git",
    "directory": "packages/animark-react"
  },
  "bugs": {
    "url": "https://github.com/anmism/animark/issues"
  },
  "keywords": [
    "react",
    "markdown",
    "animation",
    "animark",
    "remark",
    "react-markdown",
    "inline-animation",
    "presentation"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/animark.css"
  },
  "files": [
    "dist",
    "src/animark.css",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "src/animark.css"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build":          "tsc -p tsconfig.json",
    "dev":            "tsc -p tsconfig.json --watch",
    "test":           "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "animark-core":     "^1.0.0",
    "react-markdown":   "^10.1.0",
    "remark-directive": "^4.0.0"
  },
  "peerDependencies": {
    "react":     ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react":     "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup":             "^8.0.0",
    "vitest":           "^4.0.0"
  }
}